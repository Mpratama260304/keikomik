# Railway / Render / VPS env config
# Copy to .env and adjust values

# Origin website to mirror
ORIGIN_HOST=keikomik.web.id
ORIGIN_PROTOCOL=https

# Your mirror domain (WAJIB diisi agar SEO benar)
# Contoh: mirror.example.com
MIRROR_HOST=
MIRROR_PROTOCOL=https

# Port (Railway/Render set otomatis via PORT env)
PORT=3000
